{
  "name": "playwright-jest-test-framework",
  "version": "1.0.0",
  "description": "Playwright UI tests & Jest/Axios API tests",
  "scripts": {
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "test:ui:report": "npx playwright show-report",
    "test:api": "jest --config jest.config.ts",
    "test:api:report": "open jest-report.html",
    "test:all": "npm run test:ui && npm run test:api"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.3.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
